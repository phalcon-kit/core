{
  "name": "phalcon-kit/core",
  "type": "library",
  "description": "Build high-performance PHP applications faster with Phalcon Kit — a modular developer toolkit that extends the Phalcon framework.",
  "keywords": [
    "php",
    "framework",
    "php-framework",
    "phalcon",
    "phalcon-php",
    "phalcon-kit",
    "phalcon-kit-core",
    "phalcon-toolkit"
  ],
  "homepage": "https://github.com/phalcon-kit",
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "Julien Turbide",
      "email": "contact@jturbide.com",
      "homepage": "https://www.jturbide.com/"
    },
    {
      "name": "Contributors",
      "homepage": "https://github.com/phalcon-kit/core/graphs/contributors"
    }
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/jturbide"
    }
  ],
  "support": {
    "docs": "https://github.com/phalcon-kit/core/tree/master/guides",
    "issues": "https://github.com/phalcon-kit/core/issues",
    "security": "https://github.com/phalcon-kit/core/security/policy",
    "source": "https://github.com/phalcon-kit/core"
  },
  "config": {
    "optimize-autoloader": true,
    "apcu-autoloader": true,
    "apcu-autoloader-prefix": "phalcon-kit-",
    "process-timeout": 0,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "cweagans/composer-patches": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.5",
    "ext-intl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-phalcon": "^5.13",
    "ext-sodium": "*",
    "docopt/docopt": "^1.0.6",
    "league/flysystem": "^3.34.0",
    "league/fractal": "^0.21",
    "phalcon/incubator-mailer": "^3.0.0",
    "vlucas/phpdotenv": "^5.6.3"
  },
  "suggest": {
    "ext-apcu": "*",
    "ext-bcmath": "*",
    "ext-imap": "*",
    "ext-redis": "*",
    "ext-simplexml": "*",
    "ext-sockets": "*",
    "ext-swoole": "*",
    "ext-zend-opcache": "*",
    "aws/aws-sdk-php": "^3.369.24",
    "cweagans/composer-patches": "^2.0.0",
    "fakerphp/faker": "^1.24.1",
    "google/recaptcha": "^1.5",
    "guzzlehttp/guzzle": "^7.10.0",
    "jetbrains/phpstorm-attributes": "^1.2",
    "joshtronic/php-loremipsum": "^3.0.0",
    "league/csv": "^9.28.0",
    "league/oauth2-client": "^2.9.0",
    "league/oauth2-facebook": "^2.2.0",
    "league/oauth2-github": "^3.1.1",
    "league/oauth2-google": "^5.0",
    "league/oauth2-instagram": "^3.1.0",
    "league/oauth2-linkedin": "^5.1.2",
    "openai-php/client": "^0.19.0",
    "phalcon/ide-stubs": "^5.13",
    "php-imap/php-imap": "^6.0",
    "saggre/phpdocumentor-markdown": "^1.0.0",
    "shuchkin/simplexlsxgen": "^1.5.17",
    "spatie/array-to-xml": "^3.4.4",
    "thiagoalessio/tesseract_ocr": "^2.13.0",
    "xenolope/quahog": "^3.0.0"
  },
  "require-dev": {
    "ext-apcu": "*",
    "ext-bcmath": "*",
    "ext-gd": "*",
    "ext-imap": "*",
    "ext-redis": "*",
    "ext-simplexml": "*",
    "ext-sockets": "*",
    "ext-swoole": "*",
    "ext-zend-opcache": "*",
    "aws/aws-sdk-php": "^3.369.24",
    "cweagans/composer-patches": "^2.0.0",
    "fakerphp/faker": "^1.24.1",
    "google/recaptcha": "^1.5",
    "guzzlehttp/guzzle": "^7.10.0",
    "jetbrains/phpstorm-attributes": "^1.2",
    "joshtronic/php-loremipsum": "^3.0.0",
    "league/csv": "^9.28.0",
    "league/oauth2-client": "^2.9.0",
    "league/oauth2-facebook": "^2.2.0",
    "league/oauth2-github": "^3.1.1",
    "league/oauth2-google": "^5.0",
    "league/oauth2-instagram": "^3.1.0",
    "league/oauth2-linkedin": "^5.1.2",
    "openai-php/client": "^0.19.0",
    "phalcon/ide-stubs": "^5.13",
    "php-imap/php-imap": "^6.0",
    "saggre/phpdocumentor-markdown": "^1.0.0",
    "shuchkin/simplexlsxgen": "^1.5.17",
    "spatie/array-to-xml": "^3.4.4",
    "thiagoalessio/tesseract_ocr": "^2.13.0",
    "xenolope/quahog": "^3.0.0"
  },
  "autoload": {
    "psr-4": {
      "PhalconKit\\": "src/"
    },
    "files": [
      "src/Functions/Dump.php",
      "src/Functions/Array.php",
      "src/Functions/Sprintf.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "PhalconKit\\Tests\\Unit\\": "tests/Unit"
    }
  },
  "extra": {
    "patches": {
      "phalcon/ide-stubs": {
        "Phalcon\\Mvc\\Model": "patches/phalcon-mvc-model.patch",
        "Phalcon\\Mvc\\ModelInterface": "patches/phalcon-mvc-model-interface.patch",
        "Phalcon\\Mvc\\EntityInterface": "patches/phalcon-mvc-entity-interface.patch"
      }
    }
  },
  "archive": {
    "exclude": [
      "/.github",
      "/.cache",
      "/.codex",
      "/.idea",
      "/.phalcon",
      "/.phpdoc",
      "/.phpunit.cache",
      "/.run",
      "/.aiignore",
      "/.env*",
      "/docs",
      "/stubs",
      "/tests",
      "/vendor",
      "AGENTS.md",
      "AI.md",
      "CHANGELOG.md",
      "composer.lock",
      "patches.lock.json",
      "phpcs-eol.xml",
      "phpcs.xml",
      "phpcs.xml.dist",
      "phpdoc.xml",
      "qodana.yaml",
      "phpstan.neon",
      "phpstan.neon.dist",
      "phpunit.xml",
      "phpunit.xml.dist",
      "psalm.xml",
      "psalm.xml.dist",
      "results.sarif",
      "taints.dot"
    ]
  },
  "bin": [
    "phalcon-kit"
  ],
  "scripts": {
    "check": "@qa",
    "outdated:direct": "composer show --direct --outdated",
    "qa": [
      "@qa:composer",
      "@qa:style",
      "@qa:static",
      "@qa:security",
      "@qa:test"
    ],
    "qa:composer": [
      "composer validate --strict --no-check-publish",
      "composer audit"
    ],
    "qa:static": [
      "./bin/phpstan.sh --no-progress",
      "./bin/psalm.sh --no-progress"
    ],
    "qa:security": "./bin/psalm.sh --taint-analysis --dump-taint-graph=taints.dot --no-progress",
    "qa:style": "./bin/phpcs.sh --report=summary",
    "qa:test": "./bin/phpunit.sh --display-skipped --display-errors",
    "skeleton": "./bin/skeleton.sh validate ./",
    "phpunit": "./bin/phpunit.sh",
    "phpstan": "./bin/phpstan.sh",
    "psalm": "./bin/psalm.sh",
    "psalm:taint": "./bin/psalm.sh --taint-analysis --dump-taint-graph=taints.dot",
    "php-cs-fixer": "./bin/php-cs-fixer.sh",
    "phpcs": "./bin/phpcs.sh",
    "phpcbf": "./bin/phpcbf.sh",
    "static": [
      "@phpstan",
      "@psalm"
    ],
    "style": "@phpcs",
    "style:fix": "@phpcbf",
    "test": "@phpunit",
    "test:coverage": "./bin/phpunit-coverage.sh",
    "test:unit": "@phpunit",
    "docs": "phpDocumentor -c phpdoc.xml"
  },
  "scripts-descriptions": {
    "check": "Alias for the full QA gate.",
    "outdated:direct": "Show outdated direct dependencies only.",
    "qa": "Run Composer validation/audit, coding style, static/security analysis, and PHPUnit.",
    "qa:composer": "Validate composer.json and run Composer security audit.",
    "qa:security": "Run Psalm taint analysis.",
    "qa:static": "Run PHPStan and Psalm.",
    "qa:style": "Run PHPCS with the compact summary report.",
    "qa:test": "Run PHPUnit with skipped/error details.",
    "static": "Run PHPStan and Psalm with their default local options.",
    "psalm:taint": "Run Psalm taint analysis and write taints.dot.",
    "style": "Run PHPCS.",
    "style:fix": "Run PHPCBF.",
    "test": "Run PHPUnit.",
    "test:coverage": "Run PHPUnit with coverage.",
    "test:unit": "Run PHPUnit."
  }
}
